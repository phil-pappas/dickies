---
import Bilingual from './Bilingual.astro';
import { translations } from '~/data/translations';
import { site } from '~/data/site';

const enHero = translations.en.hero;
const elHero = translations.el.hero;
const enContact = translations.en.contact;
const elContact = translations.el.contact;
---

<section id="home" class="bg-darkGreen text-eggshell">
  <div
    class="container-shell grid items-center gap-10 py-16 sm:py-20 lg:grid-cols-12 lg:gap-16 lg:py-24"
  >
    <div class="lg:col-span-7">
      <p class="font-sans text-xs uppercase tracking-[0.22em] text-freshLime">
        <span class="mr-2 inline-block h-2 w-2 rounded-full bg-freshLime align-middle"></span>
        <Bilingual en={enHero.eyebrow} el={elHero.eyebrow} />
      </p>

      <h1
        class="mt-6 font-display font-bold text-4xl leading-[0.95] text-eggshell sm:text-5xl lg:text-6xl"
      >
        “<Bilingual en={enContact.closingCtaTitle} el={elContact.closingCtaTitle} />”
      </h1>

      <dl
        class="mt-10 grid max-w-md grid-cols-2 gap-x-6 gap-y-4 border-t border-eggshell/15 pt-6"
      >
        <div>
          <dt class="font-sans text-[11px] uppercase tracking-brand text-eggshell/60">
            <Bilingual en="Hours" el="Ώρες" />
          </dt>
          <dd class="mt-1 font-sans text-base font-medium text-eggshell">
            <Bilingual en={enHero.hoursBadge} el={elHero.hoursBadge} />
          </dd>
        </div>
        <div>
          <dt class="font-sans text-[11px] uppercase tracking-brand text-eggshell/60">
            <Bilingual en="Where" el="Πού" />
          </dt>
          <dd class="mt-1 font-sans text-base font-medium text-eggshell">
            <Bilingual en={enHero.locationBadge} el={elHero.locationBadge} />
          </dd>
        </div>
      </dl>
    </div>

    <figure class="lg:col-span-5">
      <div class="overflow-hidden rounded-card">
        <img
          src={site.images.posterDark}
          alt={enContact.closingImageAlt}
          width="4000"
          height="2250"
          class="aspect-[16/9] w-full object-cover"
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />
      </div>
    </figure>
  </div>
</section>
