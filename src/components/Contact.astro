---
import Bilingual from './Bilingual.astro';
import { translations } from '~/data/translations';
import { site } from '~/data/site';

const en = translations.en.contact;
const el = translations.el.contact;

// Build a list of "available" rows so missing details produce zero UI
// (the brief explicitly forbids inventing phone, email or social handles).
type Row = {
  labelEn: string;
  labelEl: string;
  value: string;
  href?: string;
  icon: 'pin' | 'clock' | 'phone' | 'mail' | 'instagram' | 'whatsapp';
};

const rows: Row[] = [
  {
    labelEn: en.locationLabel,
    labelEl: el.locationLabel,
    value: en.locationValue,
    icon: 'pin',
    href: site.location.mapsUrl ?? undefined,
  },
  {
    labelEn: en.hoursLabel,
    labelEl: el.hoursLabel,
    value: en.hoursValue,
    icon: 'clock',
  },
];

if (site.contact.phone) {
  rows.push({
    labelEn: en.phoneLabel,
    labelEl: el.phoneLabel,
    value: site.contact.phone,
    href: `tel:${site.contact.phone.replace(/\s+/g, '')}`,
    icon: 'phone',
  });
}
if (site.contact.email) {
  rows.push({
    labelEn: en.emailLabel,
    labelEl: el.emailLabel,
    value: site.contact.email,
    href: `mailto:${site.contact.email}`,
    icon: 'mail',
  });
}

const socials: { kind: 'instagram' | 'whatsapp'; url: string; labelEn: string; labelEl: string }[] = [];
if (site.social.instagram.url) {
  socials.push({
    kind: 'instagram',
    url: site.social.instagram.url,
    labelEn: en.instagramLabel,
    labelEl: el.instagramLabel,
  });
}
if (site.social.whatsapp.url) {
  socials.push({
    kind: 'whatsapp',
    url: site.social.whatsapp.url,
    labelEn: en.whatsappLabel,
    labelEl: el.whatsappLabel,
  });
}
---

<section id="contact" class="bg-white">
  <div class="container-shell grid gap-10 py-20 sm:py-24 lg:grid-cols-12 lg:gap-16">
    <div class="lg:col-span-5">
      <p class="eyebrow">
        <Bilingual en={en.eyebrow} el={el.eyebrow} />
      </p>
      <h2 class="display-h2 mt-5">
        <Bilingual en={en.title} el={el.title} />
      </h2>
      <p class="lead mt-5 max-w-prose">
        <Bilingual en={en.subtitle} el={el.subtitle} />
      </p>

      {
        socials.length > 0 && (
          <div class="mt-8 flex items-center gap-3">
            {socials.map((s) => (
              <a
                href={s.url}
                rel="noopener noreferrer"
                target="_blank"
                aria-label={s.labelEn}
                class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-darkGreen/15 bg-eggshell text-darkGreen transition-colors hover:border-forestMoss hover:bg-forestMoss hover:text-eggshell"
              >
                {s.kind === 'instagram' ? (
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5" aria-hidden="true">
                    <rect x="3" y="3" width="18" height="18" rx="5" ry="5" />
                    <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
                    <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" />
                  </svg>
                ) : (
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5" aria-hidden="true">
                    <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8z" />
                  </svg>
                )}
              </a>
            ))}
          </div>
        )
      }
    </div>

    <div class="lg:col-span-7">
      <dl class="grid gap-4 rounded-card bg-eggshell p-6 ring-1 ring-darkGreen/10 sm:grid-cols-2 sm:p-8">
        {
          rows.map((row) => (
            <div class="flex items-start gap-4">
              <span class="mt-1 inline-flex h-9 w-9 flex-none items-center justify-center rounded-full bg-white text-forestMoss ring-1 ring-darkGreen/10">
                {row.icon === 'pin' && (
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4" aria-hidden="true">
                    <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 1 1 18 0z" />
                    <circle cx="12" cy="10" r="3" />
                  </svg>
                )}
                {row.icon === 'clock' && (
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4" aria-hidden="true">
                    <circle cx="12" cy="12" r="9" />
                    <polyline points="12 7 12 12 15 14" />
                  </svg>
                )}
                {row.icon === 'phone' && (
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4" aria-hidden="true">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
                  </svg>
                )}
                {row.icon === 'mail' && (
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4" aria-hidden="true">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                    <polyline points="22,6 12,13 2,6" />
                  </svg>
                )}
              </span>
              <div>
                <dt class="font-sans text-[11px] uppercase tracking-brand text-darkGreen/60">
                  <Bilingual en={row.labelEn} el={row.labelEl} />
                </dt>
                <dd class="mt-1 font-sans text-base font-medium text-darkGreen">
                  {row.href ? (
                    <a
                      href={row.href}
                      class="underline decoration-freshLime decoration-2 underline-offset-4 hover:text-forestMoss"
                      target={row.href.startsWith('http') ? '_blank' : undefined}
                      rel={row.href.startsWith('http') ? 'noopener noreferrer' : undefined}
                    >
                      {row.value}
                    </a>
                  ) : (
                    row.value
                  )}
                </dd>
              </div>
            </div>
          ))
        }
      </dl>

      {
        site.location.mapsUrl && (
          <a
            href={site.location.mapsUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-secondary mt-6"
          >
            <Bilingual en={en.mapsCta} el={el.mapsCta} />
          </a>
        )
      }
    </div>
  </div>
</section>
