---
import Bilingual from './Bilingual.astro';
import { translations } from '~/data/translations';
import { site } from '~/data/site';

const en = translations.en.contact;
const el = translations.el.contact;

type Row = {
  labelEn: string;
  labelEl: string;
  value: string;
  href?: string;
  icon: 'pin' | 'clock' | 'phone' | 'mail';
};

const rows: Row[] = [
  {
    labelEn: en.locationLabel,
    labelEl: el.locationLabel,
    value: en.locationValue,
    icon: 'pin',
    href: site.location.mapsUrl ?? undefined,
  },
  {
    labelEn: en.hoursLabel,
    labelEl: el.hoursLabel,
    value: en.hoursValue,
    icon: 'clock',
  },
];

if (site.contact.phone) {
  rows.push({
    labelEn: en.phoneLabel,
    labelEl: el.phoneLabel,
    value: site.contact.phone,
    href: `tel:${site.contact.phone.replace(/\s+/g, '')}`,
    icon: 'phone',
  });
}
if (site.contact.email) {
  rows.push({
    labelEn: en.emailLabel,
    labelEl: el.emailLabel,
    value: site.contact.email,
    href: `mailto:${site.contact.email}`,
    icon: 'mail',
  });
}

const socials: { kind: 'instagram' | 'whatsapp'; url: string; labelEn: string; labelEl: string }[] = [];
if (site.social.instagram.url) {
  socials.push({
    kind: 'instagram',
    url: site.social.instagram.url,
    labelEn: en.instagramLabel,
    labelEl: el.instagramLabel,
  });
}
if (site.social.whatsapp.url) {
  socials.push({
    kind: 'whatsapp',
    url: site.social.whatsapp.url,
    labelEn: en.whatsappLabel,
    labelEl: el.whatsappLabel,
  });
}
---

<section id="contact" class="bg-white">
  <div class="container-shell grid gap-10 py-20 sm:py-24 lg:grid-cols-12 lg:gap-16">
    <div class="lg:col-span-5">
      <p class="eyebrow">
        <Bilingual en={en.eyebrow} el={el.eyebrow} />
      </p>
      <h2 class="display-h2 mt-5">
        <Bilingual en={en.title} el={el.title} />
      </h2>
      <p class="lead mt-5 max-w-prose">
        <Bilingual en={en.subtitle} el={el.subtitle} />
      </p>
    </div>

    <div class="lg:col-span-7">
      <dl class="grid gap-4 rounded-card bg-eggshell p-6 ring-1 ring-darkGreen/10 sm:grid-cols-2 sm:p-8">
        {
          rows.map((row) => (
            <div class="flex items-start gap-4">
              <span class="mt-1 inline-flex h-9 w-9 flex-none items-center justify-center rounded-full bg-white text-forestMoss ring-1 ring-darkGreen/10">
                {row.icon === 'pin' && (
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4" aria-hidden="true">
                    <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 1 1 18 0z" />
                    <circle cx="12" cy="10" r="3" />
                  </svg>
                )}
                {row.icon === 'clock' && (
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4" aria-hidden="true">
                    <circle cx="12" cy="12" r="9" />
                    <polyline points="12 7 12 12 15 14" />
                  </svg>
                )}
                {row.icon === 'phone' && (
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4" aria-hidden="true">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
                  </svg>
                )}
                {row.icon === 'mail' && (
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4" aria-hidden="true">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                    <polyline points="22,6 12,13 2,6" />
                  </svg>
                )}
              </span>
              <div>
                <dt class="font-sans text-[11px] uppercase tracking-brand text-darkGreen/60">
                  <Bilingual en={row.labelEn} el={row.labelEl} />
                </dt>
                <dd class="mt-1 font-sans text-base font-medium text-darkGreen">
                  {row.href ? (
                    <a
                      href={row.href}
                      class="hover:text-forestMoss"
                      target={row.href.startsWith('http') ? '_blank' : undefined}
                      rel={row.href.startsWith('http') ? 'noopener noreferrer' : undefined}
                    >
                      {row.value}
                    </a>
                  ) : (
                    row.value
                  )}
                </dd>
              </div>
            </div>
          ))
        }

        {/* Each social is its own grid cell so WhatsApp auto-fills the
             bottom-left slot and Instagram is pinned to the right column. */}
        {socials.filter(s => s.kind === 'whatsapp').map((s) => (
          <a href={s.url} rel="noopener noreferrer" target="_blank" class="group flex items-center gap-4">
            <span class="inline-flex h-9 w-9 flex-none items-center justify-center rounded-full bg-white text-forestMoss ring-1 ring-darkGreen/10 transition-colors group-hover:bg-forestMoss group-hover:text-eggshell group-hover:ring-forestMoss">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347zM11.99 2C6.477 2 2 6.477 2 11.99c0 1.762.46 3.442 1.26 4.91L2 22l5.236-1.236A9.963 9.963 0 0 0 11.99 22C17.523 22 22 17.523 22 11.99S17.523 2 11.99 2z" />
              </svg>
            </span>
            <div>
              <p class="font-sans text-[11px] uppercase tracking-brand text-darkGreen/60">WhatsApp</p>
              <p class="mt-0.5 font-sans text-base font-medium text-darkGreen transition-colors group-hover:text-forestMoss">
                <Bilingual en="Message us" el="Στείλε μήνυμα" />
              </p>
            </div>
          </a>
        ))}

        {socials.filter(s => s.kind === 'instagram').map((s) => (
          <a href={s.url} rel="noopener noreferrer" target="_blank" class="group flex items-center gap-4 sm:col-start-2">
            <span class="inline-flex h-9 w-9 flex-none items-center justify-center rounded-full bg-white text-forestMoss ring-1 ring-darkGreen/10 transition-colors group-hover:bg-forestMoss group-hover:text-eggshell group-hover:ring-forestMoss">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="5" ry="5" />
                <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
                <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" />
              </svg>
            </span>
            <div>
              <p class="font-sans text-[11px] uppercase tracking-brand text-darkGreen/60">Instagram</p>
              <p class="mt-0.5 font-sans text-base font-medium text-darkGreen transition-colors group-hover:text-forestMoss">
                <Bilingual en="Follow us" el="Ακολούθησέ μας" />
              </p>
            </div>
          </a>
        ))}
      </dl>

      {
        site.location.mapsUrl && (
          <a
            href={site.location.mapsUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-secondary mt-6"
          >
            <Bilingual en={en.mapsCta} el={el.mapsCta} />
          </a>
        )
      }
    </div>
  </div>
</section>
